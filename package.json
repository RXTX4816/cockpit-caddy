{
  "type": "module",
  "name": "cockpit-caddy",
  "version": "0.0.0",
  "description": "Caddy reverse proxy management plugin for Cockpit",
  "author": "RXTX4816",
  "license": "MIT",
  "homepage": "https://github.com/RXTX4816/cockpit-caddy",
  "repository": {
    "type": "git",
    "url": "https://github.com/RXTX4816/cockpit-caddy.git"
  },
  "scripts": {
    "build": "node scripts/build.mjs && cockpit-i18n-check",
    "watch": "node scripts/watch.mjs",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "test": "NODE_OPTIONS='--max-old-space-size=8192 --disable-warning=ExperimentalWarning' vitest run",
    "test:watch": "NODE_OPTIONS='--disable-warning=ExperimentalWarning' vitest",
    "test:coverage": "NODE_OPTIONS='--max-old-space-size=8192 --disable-warning=ExperimentalWarning' vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:codegen": "playwright codegen",
    "build:watch": "npm run watch",
    "vm": "node_modules/@rxtx4816/cockpit-plugin-base-react/scripts/test-vm.sh",
    "base:add": "echo '⚠ Run `yalc push` in cockpit-plugin-base-react first' && yalc add @rxtx4816/cockpit-plugin-base-react && npm install",
    "base:reset": "yalc retreat --all && npm install"
  },
  "devDependencies": {
    "@codemirror/merge": "^6.12.2",
    "@patternfly/react-core": "^6.6.0",
    "@playwright/test": "^1.61.1",
    "@rxtx4816/cockpit-plugin-base-react": "1.1.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitest/coverage-v8": "^4.1.10",
    "esbuild": "^0.28.1",
    "eslint": "^9.39.4",
    "jsdom": "^29.1.1",
    "react": "^19.2.8",
    "react-dom": "^19.2.7",
    "typescript": "^6.0.3",
    "vitest": "^4.1.10"
  },
  "overrides": {
    "react": "$react",
    "react-dom": "$react-dom",
    "scheduler": "0.27.0"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "keywords": [
    "cockpit",
    "caddy",
    "reverse-proxy",
    "tls",
    "management"
  ],
  "dependencies": {
    "@codemirror/theme-one-dark": "^6.1.3",
    "codemirror": "^6.0.2",
    "i18next": "^26.3.6",
    "react-i18next": "^17.0.10"
  }
}
